{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "spring2025-81f5b",
          "appId": "1:944422012610:android:a205c56c9180152b5b5d5b",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "spring2025-81f5b",
          "appId": "1:944422012610:ios:c68887c565b144685b5d5b",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "spring2025-81f5b",
          "appId": "1:944422012610:ios:1c73d37a831e3c015b5d5b",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "web": {
        "default": {
          "projectId": "spring2025-81f5b",
          "appId": "1:944422012610:web:501753444f6ae7875b5d5b",
          "fileOutput": "web/firebase-config.js"
        }
      },
      "windows": {
        "default": {
          "projectId": "spring2025-81f5b",
          "appId": "1:944422012610:web:ef76cd8cab15eaf35b5d5b",
          "fileOutput": "windows/firebase-config.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "spring2025-81f5b",
          "configurations": {
            "android": "1:944422012610:android:a205c56c9180152b5b5d5b",
            "ios": "1:944422012610:ios:c68887c565b144685b5d5b",
            "macos": "1:944422012610:ios:1c73d37a831e3c015b5d5b",
            "web": "1:944422012610:web:501753444f6ae7875b5d5b",
            "windows": "1:944422012610:web:ef76cd8cab15eaf35b5d5b"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "database": {
      "port": 9000
    },
    "hosting": {
      "port": 5000
    },
    "pubsub": {
      "port": 8085
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true
    }
  }
}